# Cerebras-specific .env example.
#
# Copy this to ../.env at the service root and replace
# <paste-your-cerebras-api-key-here> with your real key.
#
# Cerebras hosts open-source models on their own hardware — typically
# much faster than other providers. Model names: see the current list at
#   https://inference-docs.cerebras.ai/api-reference/models
#
# This example uses gpt-oss-120b (OpenAI's open-source GPT model).

# ─── REQUIRED ────────────────────────────────────────────────────────────

# Shared secret the platform sends with every request.
# Generate with: openssl rand -hex 32
BOT_SHARED_SECRET=replace_with_a_long_random_string

# Local SQLite file (no server needed). The directory will be created
# if missing. Use ":memory:" for an ephemeral test database.
BOT_DB_PATH=./companion.db

# ─── CEREBRAS PROVIDER ───────────────────────────────────────────────────

BOT_LLM_PRIMARY=cerebras:gpt-oss-120b
BOT_LLM_FALLBACK=cerebras:gpt-oss-120b
CEREBRAS_API_KEY=<paste-your-cerebras-api-key-here>

# Tip: if you also have an OpenAI or Anthropic key, set the fallback to a
# different vendor so a Cerebras outage doesn't take you offline:
#
#   BOT_LLM_FALLBACK=openai:gpt-4o-mini
#   OPENAI_API_KEY=sk-...

# ─── BEHAVIOUR (sensible defaults; tune if needed) ───────────────────────

BOT_PLATFORM_NAME=Platform
BOT_PROMPT_VERSION=v2

BOT_LLM_TIMEOUT_SECONDS=30
BOT_MAX_OUTPUT_TOKENS=800
BOT_TEMPERATURE=0.4

# Per-user history retention (default 30 days).
BOT_HISTORY_TTL_SECONDS=2592000

# Summarize history older than this many messages.
BOT_HISTORY_SUMMARIZE_THRESHOLD=10
BOT_HISTORY_KEEP_RECENT=2

# Reply length bounds (chars).
BOT_MIN_REPLY_CHARS=5
BOT_MAX_REPLY_CHARS=2000

# ─── SAFETY ──────────────────────────────────────────────────────────────

# "openai" (uses OpenAI's free moderation API; needs OPENAI_API_KEY),
# "none" (skip moderation — fine for local dev), or "llama_guard".
# For pure Cerebras setups, "none" works for dev. For production, set
# OPENAI_API_KEY and use "openai".
BOT_MODERATION_PROVIDER=none

# ─── ADMIN DASHBOARD ─────────────────────────────────────────────────────

# Set this to enable the dashboard at /admin and the /admin/* JSON APIs.
# Use any long random string. Different from BOT_SHARED_SECRET.
BOT_ADMIN_TOKEN=replace_with_a_different_long_random_string

# ─── LOGGING ─────────────────────────────────────────────────────────────

BOT_LOG_LEVEL=INFO
