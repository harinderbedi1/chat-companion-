# ═════════════════════════════════════════════════════════════════════════
# Companion service — environment configuration
#
# Copy this file to `.env` (next to it), then fill in the values marked
# with `# CHANGE ME`. Everything else has a sensible default.
#
# This file is safe to commit; the real `.env` is in .gitignore.
# ═════════════════════════════════════════════════════════════════════════


# ─── 1. Secrets you make up yourself (NOT fetched from anywhere) ─────────

# What the platform sends with every chat request. The platform team
# needs the SAME value on their side. Generate one with:
#     openssl rand -hex 32
# You can also pass multiple values comma-separated to rotate the secret
# without downtime (we'll accept any of them).
# CHANGE ME
BOT_SHARED_SECRET=replace_with_a_long_random_string

# What you sign in to the admin dashboard with. You make this up; it's
# NOT an API key from any service. Generate the same way as above.
# Must be different from BOT_SHARED_SECRET.
# If left unset, /admin returns 503.
# CHANGE ME
BOT_ADMIN_TOKEN=replace_with_a_different_long_random_string

# Auth mode: "body" (the platform sends BOT_SHARED_SECRET in JSON body —
# simplest), or "hmac_header" (HMAC-SHA256 over the body — more secure).
BOT_AUTH_MODE=body


# ─── 2. Where the database file lives ────────────────────────────────────

# SQLite file. Created on first run; no separate server needed.
# Inside Docker this is overridden to /data/companion.db (persistent volume).
BOT_DB_PATH=./companion.db


# ─── 3. AI provider — default is Cerebras (very fast Llama hosting) ──────

# https://cloud.cerebras.ai — get a free key, paste it below.
# Model names change; current list at:
#   https://inference-docs.cerebras.ai/api-reference/models
BOT_LLM_PRIMARY=cerebras:gpt-oss-120b
BOT_LLM_FALLBACK=cerebras:gpt-oss-120b
# CHANGE ME
CEREBRAS_API_KEY=

# ─── Alternative providers — uncomment ONE block and comment out Cerebras ─

# ── OpenAI only ──────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
# BOT_LLM_PRIMARY=openai:gpt-4o
# BOT_LLM_FALLBACK=openai:gpt-4o-mini
# OPENAI_API_KEY=

# ── Anthropic primary + OpenAI fallback (two vendors, more resilient) ────
# BOT_LLM_PRIMARY=anthropic:claude-sonnet-4-6
# BOT_LLM_FALLBACK=openai:gpt-4o-mini
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Cerebras primary + OpenAI fallback (best of both) ────────────────────
# BOT_LLM_PRIMARY=cerebras:gpt-oss-120b
# BOT_LLM_FALLBACK=openai:gpt-4o-mini
# CEREBRAS_API_KEY=
# OPENAI_API_KEY=

# ── Fully local (Ollama, no internet) ────────────────────────────────────
# https://ollama.com  Pull the model first: `ollama pull llama3.1:70b-instruct`
# BOT_LLM_PRIMARY=ollama:llama3.1:70b-instruct
# BOT_LLM_FALLBACK=ollama:llama3.1:8b-instruct
# BOT_LLM_PRIMARY_BASE_URL=http://localhost:11434
# BOT_LLM_FALLBACK_BASE_URL=http://localhost:11434


# ─── 4. Safety check on the AI's reply ───────────────────────────────────

# Choose how outgoing replies are screened:
#   "openai"      — calls OpenAI's free omni-moderation API (needs OPENAI_API_KEY)
#   "llama_guard" — calls a local Llama Guard 3 endpoint
#   "none"        — skip the moderation step (dev/test only)
#
# Default is "none" because the Cerebras-only setup above doesn't have
# an OpenAI key. Switch to "openai" once you set OPENAI_API_KEY.
BOT_MODERATION_PROVIDER=none


# ─── 5. Behaviour you probably won't need to change ──────────────────────

BOT_PLATFORM_NAME=Platform
BOT_PROMPT_VERSION=v2

# LLM tuning
BOT_LLM_TIMEOUT_SECONDS=30
BOT_MAX_OUTPUT_TOKENS=800
BOT_TEMPERATURE=0.5

# Per-user history is kept for this many seconds (default 30 days).
BOT_HISTORY_TTL_SECONDS=2592000

# When stored history grows past this many messages we summarize the older
# ones into 2-3 sentences and keep this many recent messages raw.
BOT_HISTORY_SUMMARIZE_THRESHOLD=10
BOT_HISTORY_KEEP_RECENT=2

# Replies shorter or longer than these are rejected by the safety gate.
BOT_MIN_REPLY_CHARS=5
BOT_MAX_REPLY_CHARS=2000


# ─── 6. Logging / tracing (all optional) ─────────────────────────────────

BOT_LOG_LEVEL=INFO

# Self-hosted Langfuse captures full prompt + response per request.
# Leave commented if you don't have a Langfuse instance.
# BOT_LANGFUSE_HOST=https://langfuse.example.com
# BOT_LANGFUSE_PUBLIC_KEY=
# BOT_LANGFUSE_SECRET_KEY=
